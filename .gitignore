# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
*.log

# Environment files — NEVER commit real credentials
.env
.env.*
!.env.example

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
-files  grep .env

# Temporary files
*.tmp
*.temp
.cache/

# Large binary / data files — do NOT push to GitHub
*.zip
*.xls
*.xlsx

# Large SQL dumps — keep migration scripts but not full data backups
current.sql
Necessaire.sql
hr_data.sql
hr_operations_platform_existing_data_temp.sql
hr_schema.sql
users_hr.sql

# Uploads (user-uploaded files — use Docker volumes instead)
uploads/
*/uploads/

# Word/PDF documents (employee files)
*.docx
*.pdf
