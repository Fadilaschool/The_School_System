# ─── DATABASE ─────────────────────────────────────────────────────────────────
# In Docker: DB_HOST must be "postgres" (the service name)
# Locally:   DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hr_operations_platform
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_VERY_LONG_RANDOM_STRING_MIN_64_CHARS
JWT_EXPIRES_IN=24h

# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── SERVICE PORTS ────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
USER_MANAGEMENT_SERVICE_PORT=3002
DEPARTMENT_SERVICE_PORT=3003
TASK_SERVICE_PORT=3020
MEETING_SERVICE_PORT=3005
PAYMENT_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
ATTENDANCE_SERVICE_PORT=3000
REQUEST_SERVICE_PORT=3009
TIMETABLE_SERVICE_PORT=3011
SaLARY_SERVICE_PORT=3010

# ─── FILE UPLOADS ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ─── AI / EXTERNAL API KEYS ───────────────────────────────────────────────────
GOOGLE_API_KEY=CHANGE_ME
GROQ_API_KEY=CHANGE_ME
HF_ACCESS_TOKEN=CHANGE_ME
